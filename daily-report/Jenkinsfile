// Jenkinsfile for Polymarket Daily Portfolio Report
// This pipeline runs daily to generate portfolio reports for all accounts

pipeline {
    agent any

    // Schedule: Run daily at 09:00 Asia/Seoul regardless of controller timezone.
    triggers {
        cron('TZ=Asia/Seoul\n0 9 * * *')
    }

    // Environment variables
    environment {
        // Python environment
        PYTHONUNBUFFERED = '1'

        // Account 1 - golden-apple
        ACCOUNT_1_NAME = 'golden-apple'
        ACCOUNT_1_ADDRESS = credentials('polymarket-golden-apple-1-address')

        // Account 2 - golden-banana
        ACCOUNT_2_NAME = 'golden-banana'
        ACCOUNT_2_ADDRESS = credentials('polymarket-golden-banana-address')

        // Account 3 - golden-cherry
        ACCOUNT_3_NAME = 'golden-cherry'
        ACCOUNT_3_ADDRESS = credentials('polymarket-golden-cherry-address')

        // Account 4 - second golden-apple
        ACCOUNT_4_NAME = 'golden-apple'
        ACCOUNT_4_ADDRESS = credentials('polymarket-golden-apple-2-address')

        // Account 5 - reusable test slot (currently golden-honeydew)
        ACCOUNT_5_NAME = 'golden-eco'
        ACCOUNT_5_ADDRESS = credentials('polymarket-golden-eco-address')

        // Account 6 - reusable test slot (currently golden-nectarine)
        ACCOUNT_6_NAME = 'golden-fox'
        ACCOUNT_6_ADDRESS = credentials('polymarket-golden-fox-address')

        // Slack webhook URL
        SLACK_WEBHOOK_URL = credentials('polymarket-slack-webhook')

        // Supabase server-only configuration
        SUPABASE_URL = 'https://elufbvcnhitoksoofbir.supabase.co'
        SUPABASE_SECRET_KEY = credentials('polymarket-supabase-secret-key')
        REPORT_TIMEZONE = 'Asia/Seoul'
        DAILY_REPORT_LOG_FILE = "daily_report_build_${env.BUILD_NUMBER}.log"

        // Sanitized local position evidence (wallet addresses/secrets are never stored)
        DAILY_EVIDENCE_DB = 'data/daily_evidence.sqlite3'
    }

    options {
        // Keep only last 30 builds
        buildDiscarder(logRotator(numToKeepStr: '30'))

        // Timeout after 10 minutes
        timeout(time: 10, unit: 'MINUTES')

        // Don't allow concurrent builds
        disableConcurrentBuilds()
    }

    stages {
        stage('Setup') {
            steps {
                script {
                    echo "==================================================="
                    echo "Polymarket Daily Portfolio Report"
                    echo "Build: ${env.BUILD_NUMBER}"
                    echo "Time: ${new Date()}"
                    echo "==================================================="
                }

                // Check Python version
                sh 'python3 --version'

                // Reproducible dependency install from uv.lock
                dir('daily-report') {
                    sh 'uv sync --frozen'
                    sh 'uv run python ./daily_report.py check-supabase'
                }
            }
        }

        stage('Generate Report') {
            steps {
                script {
                    echo "Generating portfolio report for all accounts..."

                    // Run the daily report script
                    dir('daily-report') {
                        sh 'uv run python ./daily_report.py run'
                    }
                }
            }
        }

    }

    post {
        success {
            echo "✅ Daily report completed successfully"
        }

        failure {
            echo "❌ Daily report failed"

            // Send failure notification to Slack
            script {
                if (env.SLACK_WEBHOOK_URL) {
                    // Single-quoted Groovy keeps the credential out of Groovy
                    // interpolation; the shell expands the masked env variable.
                    sh '''
                        set +x
                        payload=$(printf '{"text":"⚠️ Polymarket Daily Report FAILED\\nBuild: %s\\nTime: %s"}' \
                            "$BUILD_NUMBER" "$(date -u +%Y-%m-%dT%H:%M:%SZ)")
                        curl --fail --show-error --silent \
                            -X POST -H 'Content-type: application/json' \
                            --data "$payload" \
                            "$SLACK_WEBHOOK_URL"
                    '''
                }
            }
        }

        always {
            // Build artifacts are a short-retention copy, not the durable evidence backup.
            archiveArtifacts artifacts: "daily-report/${env.DAILY_REPORT_LOG_FILE},daily-report/data/daily_evidence.sqlite3", allowEmptyArchive: true, fingerprint: true
            // The build log is immutable in the artifact store; do not accumulate
            // financial logs in a persistent workspace after archival.
            sh '''
                set +x
                rm -f -- "daily-report/$DAILY_REPORT_LOG_FILE"
            '''
            // Clean up workspace (optional)
            // cleanWs()
        }
    }
}
