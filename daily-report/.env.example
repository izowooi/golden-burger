# Polymarket Daily Reporter - 환경변수 예제
# 이 파일을 .env로 복사하고 실제 값을 입력하세요

# ============================================================
# 계좌 설정 (Account Configuration)
# ============================================================

# 계좌 1 - golden-apple
ACCOUNT_1_NAME=golden-apple
ACCOUNT_1_ADDRESS=0x1234567890abcdef1234567890abcdef12345678

# 계좌 2 - golden-banana
ACCOUNT_2_NAME=golden-banana
ACCOUNT_2_ADDRESS=0xabcdefabcdefabcdefabcdefabcdefabcdefabcd

# 계좌 3 - golden-cherry
ACCOUNT_3_NAME=golden-cherry
ACCOUNT_3_ADDRESS=0x9876543210fedcba9876543210fedcba98765432

# 계좌 4 - 두 번째 golden-apple
ACCOUNT_4_NAME=golden-apple
ACCOUNT_4_ADDRESS=0x1111111111111111111111111111111111111111

# 계좌 5 - 테스트 슬롯 (현재 golden-honeydew)
ACCOUNT_5_NAME=golden-eco
ACCOUNT_5_ADDRESS=0x2222222222222222222222222222222222222222

# 계좌 6 - 테스트 슬롯 (현재 golden-nectarine)
ACCOUNT_6_NAME=golden-fox
ACCOUNT_6_ADDRESS=0x3333333333333333333333333333333333333333

# ============================================================
# Slack 알림 설정 (Slack Notification)
# ============================================================

# Slack Webhook URL
# https://api.slack.com/apps 에서 생성
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ============================================================
# Supabase 적재 설정 (서버 전용)
# ============================================================

# Settings → API Keys → Secret keys에서 확인합니다.
# sb_publishable_... 키를 넣으면 안 됩니다.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SECRET_KEY=sb_secret_replace_with_server_only_key

# 리포트 날짜 기준 시간대
REPORT_TIMEZONE=Asia/Seoul
DAILY_REPORT_LOG_FILE=daily_report_local.log

# 지갑 주소/비밀값을 제외한 일별 포지션 evidence SQLite
DAILY_EVIDENCE_DB=data/daily_evidence.sqlite3

# ============================================================
# 선택 사항 (Optional Settings)
# ============================================================

# 로그 레벨 (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# 타임아웃 설정 (초)
API_TIMEOUT=30

# 재시도 횟수
MAX_RETRIES=3
