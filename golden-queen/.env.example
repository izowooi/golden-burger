# Secrets: keep real values only in an untracked .env or Jenkins Credentials Binding.
POLYMARKET_PRIVATE_KEY=
POLYMARKET_FUNDER_ADDRESS=

# Account-specific signing scheme: 1=proxy/Magic.Link, 3=POLY_1271.
POLYMARKET_SIGNATURE_TYPE=1

# Optional single sizing knob. The repository default is $100.
# Raising this value automatically raises liquidity, 24h volume, and exposure gates.
POLYBOT_BUY_AMOUNT=100

# Exceptional operations only; omit these during normal use.
# POLYBOT_LIFECYCLE_MODE=active
# POLYBOT_LIFECYCLE_MODE=close_only
# POLYBOT_ENTRY_HOURS_MAX=12
# Exact Gamma tag match only; omit to include every category, including sports.
# POLYBOT_EXCLUDED_CATEGORIES=sports,nba,soccer
# POLYBOT_REJECT_SPORTS_WITHOUT_GAME_START=true
