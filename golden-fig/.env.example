# Polymarket API Authentication
# Get your private key from: https://polymarket.com/settings?tab=export-private-key
POLYMARKET_PRIVATE_KEY=

# Your wallet address (funder address)
# Get from: https://polymarket.com/settings?tab=export-private-key
POLYMARKET_FUNDER_ADDRESS=

# Optional: Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Optional lifecycle mode: active (default), close_only, archive_only
# close_only keeps snapshots/exits but blocks new buys. Cancel existing GTC BUYs once.
POLYBOT_LIFECYCLE_MODE=active
