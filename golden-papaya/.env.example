# Secrets: keep real values only in an untracked .env or Jenkins Credentials Binding.
POLYMARKET_PRIVATE_KEY=
POLYMARKET_FUNDER_ADDRESS=

# Account-specific signing scheme: 1=proxy/Magic.Link, 3=POLY_1271.
POLYMARKET_SIGNATURE_TYPE=1

# Lifecycle and fixed Final Five baseline.
POLYBOT_LIFECYCLE_MODE=active
POLYBOT_BUY_AMOUNT=5
POLYBOT_MIN_LIQUIDITY=1000
POLYBOT_MIN_VOLUME_24H=0
POLYBOT_REENTRY_COOLDOWN_HOURS=24
POLYBOT_MAX_SNAPSHOT_GAP_MINUTES=30
POLYBOT_MIN_ORDER_SIZE=5
POLYBOT_MIN_ORDER_BUFFER_SHARES=0.10
POLYBOT_YES_ONLY=true
POLYBOT_EXCLUDED_CATEGORIES=
POLYBOT_ENTRY_PROB_MIN=0.95
POLYBOT_ENTRY_PROB_MAX=0.97
POLYBOT_ENTRY_HOURS_MIN=2
POLYBOT_ENTRY_HOURS_MAX=72
POLYBOT_STOP_PRICE=0.90
POLYBOT_MAX_POSITIONS=20
POLYBOT_MAX_EVENT_POSITIONS=1
POLYBOT_ARCHIVE_PROB_MIN=0.80
POLYBOT_ARCHIVE_HOURS_MAX=168
POLYBOT_SNAPSHOT_RETENTION_DAYS=60

LOG_LEVEL=INFO
